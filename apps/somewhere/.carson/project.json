{
  "template": "@jakubmazanec/carson-templates:projects/app",
  "deployment": {
    "appName": "somewhere"
  },
  "overrides": {
    "viteConfig": {
      "build": {
        "target": "ES2022"
      }
    },
    "eslintConfig": [
      {
        "ignores": ["$/**"]
      },
      {
        "rules": {
          "unicorn/prefer-dom-node-remove": "off"
        }
      }
    ],
    "tsconfig": {
      "compilerOptions": {
        "module": "preserve",
        "moduleResolution": "bundler"
      }
    }
  }
}
